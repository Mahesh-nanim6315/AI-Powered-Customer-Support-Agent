generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // connection URL moved to prisma.config.ts per Prisma 7 requirements
}

model Organization {
  id               String          @id @default(uuid())
  name             String
  subscriptionTier String          @default("FREE")
  aiEnabled        Boolean         @default(true)
  users            User[]
  memberships      OrganizationMember[]
  invites          Invite[]
  customers        Customer[]
  tickets          Ticket[]
  knowledgeBase    KnowledgeBase[]
  createdAt        DateTime        @default(now())
  aiSuggestions    AiSuggestion[]
}

model User {
  id        String       @id @default(uuid())
  orgId     String
  email     String       @unique
  password  String
  role      Role
  agent     Agent?
  memberships OrganizationMember[]
  acceptedInvites Invite[] @relation("InviteAcceptedByUser")
  org       Organization @relation(fields: [orgId], references: [id])
  createdAt DateTime     @default(now())
  tickets   Ticket[]
}

model Customer {
  id        String       @id @default(uuid())
  orgId     String
  email     String
  name      String
  metadata  Json?
  org       Organization @relation(fields: [orgId], references: [id])
  tickets   Ticket[]
  createdAt DateTime     @default(now())
}

model Ticket {
  id              String          @id @default(uuid())
  createdByUserId String?
  orgId           String
  customerId      String
  status          TicketStatus    @default(OPEN)
  priority        Priority        @default(MEDIUM)
  subject         String
  description     String?
  messages        TicketMessage[]
  refunds         Refund[]

  assignedAgentId String?
  assignedAgent   Agent?           @relation(fields: [assignedAgentId], references: [id])
  org             Organization     @relation(fields: [orgId], references: [id])
  customer        Customer         @relation(fields: [customerId], references: [id])
  createdByUser   User?            @relation(fields: [createdByUserId], references: [id])
  analytics       TicketAnalytics?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  aiSuggestions   AiSuggestion[]
}

enum Role {
  ADMIN
  AGENT
  CUSTOMER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum TicketStatus {
  OPEN
  AI_HANDLING
  ESCALATED
  IN_PROGRESS
  WAITING_FOR_HUMAN
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

model TicketMessage {
  id        String      @id @default(uuid())
  ticketId  String
  senderId  String?
  role      MessageRole
  content   String
  createdAt DateTime    @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id])
}

enum MessageRole {
  CUSTOMER
  AGENT
  AI
}

model Agent {
  id              String    @id @default(uuid())
  userId          String    @unique
  specialization  String?
  busyStatus      Boolean   @default(false)
  activeTickets   Int       @default(0)
  lastAssignedAt  DateTime?
  assignedTickets Ticket[]
  user            User      @relation(fields: [userId], references: [id])
}

model OrganizationMember {
  id        String       @id @default(uuid())
  userId    String
  orgId     String
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id])
  org  Organization @relation(fields: [orgId], references: [id])

  @@unique([userId, orgId])
  @@index([orgId])
}

model Invite {
  id               String       @id @default(uuid())
  orgId            String
  email            String
  role             Role         @default(AGENT)
  token            String       @unique
  status           InviteStatus @default(PENDING)
  expiresAt        DateTime
  acceptedByUserId String?
  acceptedAt       DateTime?
  createdAt        DateTime     @default(now())

  org Organization @relation(fields: [orgId], references: [id])
  acceptedByUser User? @relation("InviteAcceptedByUser", fields: [acceptedByUserId], references: [id])

  @@index([orgId])
  @@index([email])
}

model AgentLog {
  id        String   @id @default(cuid())
  ticketId  String
  content   String
  createdAt DateTime @default(now())
}

model Refund {
  id        String   @id @default(uuid())
  ticketId  String
  amount    Float
  token     String   @unique
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id])
}

model TicketAnalytics {
  id             String   @id @default(uuid())
  ticketId       String   @unique
  sentimentScore Float?
  createdAt      DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id])
}

model KnowledgeBase {
  id        String   @id @default(uuid())
  orgId     String
  title     String
  content   String
  createdAt DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id])
}

model AiSuggestion {
  id         String           @id @default(uuid())
  orgId      String
  ticketId   String
  actionType String
  params     Json
  status     SuggestionStatus @default(PENDING)
  createdAt  DateTime         @default(now())
  decidedAt  DateTime?

  org    Organization @relation(fields: [orgId], references: [id])
  ticket Ticket       @relation(fields: [ticketId], references: [id])
}

enum SuggestionStatus {
  PENDING
  APPROVED
  REJECTED
  EXECUTED
}
