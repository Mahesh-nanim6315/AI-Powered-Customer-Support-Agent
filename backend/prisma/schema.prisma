generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // connection URL moved to prisma.config.ts per Prisma 7 requirements
}

model Organization {
  id               String   @id @default(uuid())
  name             String
  subscriptionTier String   @default("FREE")
  users            User[]
  customers        Customer[]
  tickets          Ticket[]
  createdAt        DateTime @default(now())
}

model User {
  id        String   @id @default(uuid())
  orgId     String
  email     String   @unique
  password  String
  role      Role
  agent     Agent?
  org       Organization @relation(fields: [orgId], references: [id])
  createdAt DateTime @default(now())
}

model Customer {
  id        String   @id @default(uuid())
  orgId     String
  email     String
  name      String
  org       Organization @relation(fields: [orgId], references: [id])
  tickets   Ticket[]
}

model Ticket {
  id         String   @id @default(uuid())
  userId    String
  orgId      String
  customerId String
  status     TicketStatus @default(OPEN)
  priority   Priority     @default(MEDIUM)
  subject    String
  messages   TicketMessage[]
    refunds   Refund[]

  assignedAgentId String?
  assignedAgent   Agent?   @relation(fields: [assignedAgentId], references: [id])
  org        Organization @relation(fields: [orgId], references: [id])
  customer   Customer     @relation(fields: [customerId], references: [id])
  createdAt  DateTime     @default(now())
}

enum Role {
  ADMIN
  AGENT
}

enum TicketStatus {
  OPEN
  AI_HANDLING
  WAITING_FOR_HUMAN
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

model TicketMessage {
  id        String   @id @default(uuid())
  ticketId  String
  senderId  String?
  role      MessageRole
  content   String
  createdAt DateTime @default(now())

  ticket    Ticket   @relation(fields: [ticketId], references: [id])
}

enum MessageRole {
  CUSTOMER
  AGENT
  AI
}


model Agent {
  id             String   @id @default(uuid())
  userId         String   @unique
  specialization String?
  busyStatus     Boolean  @default(false)
  activeTickets  Int      @default(0)
  lastAssignedAt DateTime?
  assignedTickets Ticket[]
  user           User     @relation(fields: [userId], references: [id])
}

model AgentLog {
  id        String   @id @default(cuid())
  ticketId  String
  content   String
  createdAt DateTime @default(now())
}

model Refund {
  id        String   @id @default(uuid())
  userId    String
  ticketId  String
  amount    Float
  token     String   @unique
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
}