generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id               String          @id @default(uuid())
  name             String
  subscriptionTier String          @default("FREE")
  aiEnabled        Boolean         @default(true)
  users            User[]
  memberships      OrganizationMember[]
  invites          Invite[]
  customers        Customer[]
  customerInvites  CustomerInviteToken[]
  tickets          Ticket[]
  knowledgeBase    KnowledgeBase[]
  createdAt        DateTime        @default(now())
  aiSuggestions    AiSuggestion[]
  notifications    CustomerNotification[]
}

model User {
  id        String       @id @default(uuid())
  orgId     String
  email     String       @unique
  password  String
  role      Role
  agent     Agent?
  customerProfile Customer?
  messageReadReceipts MessageReadReceipt[]
  uploadedFiles FileAttachment[] @relation("UploadedFiles")
  performedAssignments TicketAssignment[] @relation("TicketAssignmentActor")
  memberships OrganizationMember[]
  acceptedInvites Invite[] @relation("InviteAcceptedByUser")
  org       Organization @relation(fields: [orgId], references: [id])
  createdAt DateTime     @default(now())
  tickets   Ticket[]
}

model Customer {
  id        String       @id @default(uuid())
  orgId     String
  email     String
  name      String
  password  String?
  userId    String?      @unique
  status    CustomerStatus @default(PENDING)
  metadata  Json?
  org       Organization @relation(fields: [orgId], references: [id])
  user      User?        @relation(fields: [userId], references: [id])
  tickets   Ticket[]
  notifications CustomerNotification[]
  inviteTokens CustomerInviteToken[]
  createdAt DateTime     @default(now())

  @@unique([orgId, email])
}

model Ticket {
  id              String          @id @default(uuid())
  createdByUserId String?
  orgId           String
  customerId      String
  status          TicketStatus    @default(OPEN)
  priority        Priority        @default(MEDIUM)
  subject         String
  description     String?
  messages        TicketMessage[]
  refunds         Refund[]

  assignedAgentId String?
  assignedAgent   Agent?           @relation(fields: [assignedAgentId], references: [id])
  org             Organization     @relation(fields: [orgId], references: [id])
  customer        Customer         @relation(fields: [customerId], references: [id])
  createdByUser   User?            @relation(fields: [createdByUserId], references: [id])
  analytics       TicketAnalytics?
  notifications   CustomerNotification[]
  assignmentHistory TicketAssignment[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  aiSuggestions   AiSuggestion[]
}

enum Role {
  ADMIN
  AGENT
  CUSTOMER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum TicketStatus {
  OPEN
  AI_IN_PROGRESS
  ESCALATED
  IN_PROGRESS
  WAITING_FOR_HUMAN
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum CustomerStatus {
  PENDING
  ACTIVE
}

model CustomerInviteToken {
  id        String   @id @default(uuid())
  orgId     String
  email     String
  token     String   @unique
  expiresAt DateTime
  customerId String?
  customer  Customer? @relation(fields: [customerId], references: [id])
  createdAt DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@index([email])
  @@index([expiresAt])
}

model TicketMessage {
  id        String      @id @default(uuid())
  ticketId  String
  senderId  String?
  role      MessageRole
  content   String
  createdAt DateTime    @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id])
  readReceipts MessageReadReceipt[]
  attachments FileAttachment[]
}

enum MessageRole {
  CUSTOMER
  AGENT
  AI
}

model MessageReadReceipt {
  messageId     String
  userId        String
  readAt        DateTime  @default(now())
  readDuration  Int?

  message TicketMessage @relation(fields: [messageId], references: [id])
  user    User          @relation(fields: [userId], references: [id])

  @@id([messageId, userId])
  @@index([userId, readAt])
}

model FileAttachment {
  id           String        @id @default(uuid())
  messageId     String
  filename      String
  originalName  String
  mimeType      String
  size          Int
  url           String
  uploadedBy    String
  createdAt     DateTime     @default(now())

  message       TicketMessage @relation(fields: [messageId], references: [id])
  uploader      User          @relation("UploadedFiles", fields: [uploadedBy], references: [id])

  @@index([messageId, createdAt])
  @@index([uploadedBy])
}

model Agent {
  id              String    @id @default(uuid())
  userId          String    @unique
  specialization  String?
  busyStatus      Boolean   @default(false)
  activeTickets   Int       @default(0)
  lastAssignedAt  DateTime?
  assignedTickets Ticket[]
  assignmentHistory TicketAssignment[]
  user            User      @relation(fields: [userId], references: [id])
}

model OrganizationMember {
  id        String       @id @default(uuid())
  userId    String
  orgId     String
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id])
  org  Organization @relation(fields: [orgId], references: [id])

  @@unique([userId, orgId])
  @@index([orgId])
}

model Invite {
  id               String       @id @default(uuid())
  orgId            String
  email            String
  role             Role         @default(AGENT)
  token            String       @unique
  status           InviteStatus @default(PENDING)
  expiresAt        DateTime
  acceptedByUserId String?
  acceptedAt       DateTime?
  createdAt        DateTime     @default(now())

  org Organization @relation(fields: [orgId], references: [id])
  acceptedByUser User? @relation("InviteAcceptedByUser", fields: [acceptedByUserId], references: [id])

  @@index([orgId])
  @@index([email])
}

model AgentLog {
  id        String   @id @default(cuid())
  ticketId  String
  content   String
  createdAt DateTime @default(now())
}

model Refund {
  id        String   @id @default(uuid())
  ticketId  String
  amount    Float
  token     String   @unique
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id])
}

model TicketAnalytics {
  id             String   @id @default(uuid())
  ticketId       String   @unique
  sentimentScore Float?
  createdAt      DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id])
}



model KnowledgeBase {
  id        String   @id @default(uuid())
  orgId     String
  title     String
  category  String   @default("General")
  content   String
  createdAt DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id])
}

model AiSuggestion {
  id         String           @id @default(uuid())
  orgId      String
  ticketId   String
  actionType String
  params     Json
  status     SuggestionStatus @default(PENDING)
  createdAt  DateTime         @default(now())
  decidedAt  DateTime?

  org    Organization @relation(fields: [orgId], references: [id])
  ticket Ticket       @relation(fields: [ticketId], references: [id])
}

enum SuggestionStatus {
  PENDING
  APPROVED
  REJECTED
  EXECUTED
}

model CustomerNotification {
  id         String           @id @default(uuid())
  customerId String
  orgId      String
  ticketId   String?
  type       NotificationType
  title      String
  message    String
  data       String?
  read       Boolean          @default(false)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  customer Customer     @relation(fields: [customerId], references: [id])
  org      Organization @relation(fields: [orgId], references: [id])
  ticket    Ticket?      @relation(fields: [ticketId], references: [id])

  @@index([customerId, orgId, read])
  @@index([orgId, createdAt])
  @@index([ticketId])
}

enum NotificationType {
  TICKET_CREATED
  TICKET_UPDATED
  TICKET_ASSIGNED
  TICKET_RESOLVED
  TICKET_ESCALATED
  MESSAGE_RECEIVED
}

model TicketAssignment {
  id               String           @id @default(uuid())
  ticketId         String
  agentId          String?
  assignedByUserId String?
  action           AssignmentAction
  reason           String?
  createdAt        DateTime         @default(now())

  ticket           Ticket           @relation(fields: [ticketId], references: [id])
  agent            Agent?           @relation(fields: [agentId], references: [id])
  assignedByUser   User?            @relation("TicketAssignmentActor", fields: [assignedByUserId], references: [id])

  @@index([ticketId, createdAt])
  @@index([agentId, createdAt])
}

enum AssignmentAction {
  ASSIGNED
  REASSIGNED
  UNASSIGNED
  AUTO_ASSIGNED
}
